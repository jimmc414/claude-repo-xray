{
  "web_api": {
    "indicators": {
      "frameworks": ["fastapi", "flask", "django", "starlette", "sanic", "tornado"],
      "patterns": ["@app.route", "@router.", "APIRouter", "Blueprint"],
      "directories": ["routes/", "api/", "views/", "endpoints/"]
    },
    "additional_investigation": [
      "Authentication and authorization middleware chain",
      "Request validation pipeline (Pydantic, marshmallow, etc.)",
      "Rate limiting implementation",
      "CORS configuration",
      "Middleware execution order",
      "Database session lifecycle (per-request? connection pool?)",
      "Background task handling (Celery, ARQ, etc.)"
    ],
    "additional_output_sections": [
      "API endpoint index (route → handler → service)",
      "Auth flow trace",
      "Middleware chain with execution order"
    ],
    "primary_entity": "API endpoint",
    "grep_patterns": {
      "auth": "authenticate\\|authorize\\|@login_required\\|Depends.*auth\\|Bearer\\|JWT",
      "middleware": "middleware\\|@app.before\\|@app.after\\|Depends(",
      "rate_limit": "rate_limit\\|throttle\\|RateLimit\\|slowapi"
    }
  },
  "cli_tool": {
    "indicators": {
      "frameworks": ["argparse", "click", "typer", "fire", "cement"],
      "patterns": ["@click.command", "@app.command", "add_argument", "ArgumentParser"],
      "directories": ["commands/", "cli/"]
    },
    "additional_investigation": [
      "Command hierarchy and subcommand structure",
      "Argument parsing and validation",
      "Output formatting strategy (JSON, table, plain text)",
      "Exit code conventions",
      "Interactive vs non-interactive mode handling",
      "Progress reporting for long operations"
    ],
    "additional_output_sections": [
      "Command tree with argument signatures",
      "Output format documentation",
      "Exit code table"
    ],
    "primary_entity": "CLI command",
    "grep_patterns": {
      "commands": "@click\\.command\\|@app\\.command\\|add_subparsers",
      "output": "click\\.echo\\|print(\\|rich\\.print\\|console\\.print",
      "exit_codes": "sys\\.exit\\|exit(\\|raise SystemExit"
    }
  },
  "ml_pipeline": {
    "indicators": {
      "frameworks": ["torch", "tensorflow", "keras", "transformers", "sklearn", "lightning"],
      "patterns": ["nn.Module", "tf.keras.Model", "model.fit", "model.train"],
      "directories": ["models/", "training/", "data/", "experiments/"]
    },
    "additional_investigation": [
      "Training loop structure and hooks",
      "Model architecture definition location",
      "Data loading and preprocessing pipeline",
      "Checkpoint save/load conventions",
      "Evaluation metrics implementation",
      "Hyperparameter configuration surface",
      "GPU/device management",
      "Experiment tracking integration"
    ],
    "additional_output_sections": [
      "Training pipeline trace (data → preprocessing → model → loss → optimizer)",
      "Model configuration surface",
      "Data flow from raw input to model input"
    ],
    "primary_entity": "model or training experiment",
    "grep_patterns": {
      "training": "def train\\|model\\.train\\|trainer\\.fit",
      "data": "DataLoader\\|Dataset\\|dataloader\\|batch_size",
      "checkpoint": "save_checkpoint\\|load_checkpoint\\|torch\\.save\\|torch\\.load"
    }
  },
  "data_pipeline": {
    "indicators": {
      "frameworks": ["airflow", "dagster", "prefect", "luigi", "dbt", "beam"],
      "patterns": ["@dag", "@task", "PythonOperator", "@op", "@asset"],
      "directories": ["dags/", "pipelines/", "etl/", "jobs/"]
    },
    "additional_investigation": [
      "DAG structure and stage dependencies",
      "Idempotency guarantees (can re-run safely?)",
      "Failure recovery and retry strategy",
      "Data validation between stages",
      "Scheduling configuration",
      "Backfill strategy",
      "Data partitioning approach"
    ],
    "additional_output_sections": [
      "DAG/pipeline stage documentation",
      "Stage-by-stage data transformation description",
      "Failure recovery procedures"
    ],
    "primary_entity": "pipeline stage or DAG",
    "grep_patterns": {
      "stages": "@task\\|@op\\|PythonOperator\\|@asset",
      "retry": "retries\\|retry_delay\\|on_failure",
      "scheduling": "schedule_interval\\|cron\\|schedule("
    }
  },
  "library": {
    "indicators": {
      "frameworks": [],
      "patterns": ["__all__", "setup.py", "pyproject.toml"],
      "directories": ["src/", "lib/"]
    },
    "additional_investigation": [
      "Public API surface (what's exported via __all__ or top-level imports)",
      "Backward compatibility constraints",
      "Extension/plugin mechanisms",
      "Thread safety guarantees",
      "Performance-critical code paths",
      "Deprecation patterns"
    ],
    "additional_output_sections": [
      "Public API index with behavioral descriptions",
      "Extension point documentation",
      "Thread safety annotations"
    ],
    "primary_entity": "public API function or class",
    "grep_patterns": {
      "public_api": "__all__\\|from.*import.*\\*",
      "deprecation": "deprecated\\|DeprecationWarning\\|warnings\\.warn",
      "thread_safety": "Lock\\|RLock\\|threading\\|asyncio\\.Lock"
    }
  },
  "scientific_computation": {
    "indicators": {
      "frameworks": ["numpy", "scipy", "matplotlib", "sympy", "pandas", "xarray"],
      "patterns": ["np.array", "np.ndarray", "scipy.optimize", "plt.figure"],
      "directories": ["analysis/", "compute/", "numerical/", "math/"]
    },
    "additional_investigation": [
      "Numerical stability patterns (overflow, underflow, precision loss)",
      "Data shape contracts (expected array dimensions at each stage)",
      "Parallelism patterns (multiprocessing, joblib, dask)",
      "Unit handling and dimensional analysis",
      "Random seed management and reproducibility",
      "Memory-intensive operations and chunking strategies"
    ],
    "additional_output_sections": [
      "Data shape flow (input dimensions → transformations → output dimensions)",
      "Numerical stability warnings",
      "Reproducibility requirements (seed, ordering, precision)"
    ],
    "primary_entity": "computation or transformation",
    "grep_patterns": {
      "numerical": "np\\.float\\|np\\.int\\|dtype\\|astype\\|float64\\|float32",
      "shapes": "\\.shape\\|\\.reshape\\|\\.transpose\\|np\\.expand_dims",
      "parallel": "multiprocessing\\|Pool\\|joblib\\|dask\\|ray\\.remote"
    }
  },
  "async_service": {
    "indicators": {
      "frameworks": ["asyncio", "aiohttp", "uvloop", "trio", "anyio", "httpx"],
      "patterns": ["async def", "await ", "asyncio.run", "asyncio.gather"],
      "directories": ["async/", "workers/", "handlers/"]
    },
    "additional_investigation": [
      "Event loop lifecycle (creation, ownership, shutdown)",
      "Sync/async boundary patterns (where sync code calls async and vice versa)",
      "Cancellation handling (task cancellation, graceful shutdown)",
      "asyncio.gather error propagation (return_exceptions usage)",
      "Connection pool management (aiohttp sessions, database pools)",
      "Structured concurrency patterns (TaskGroup, nurseries)"
    ],
    "additional_output_sections": [
      "Event loop ownership map (who creates, who runs, who shuts down)",
      "Sync/async boundary inventory",
      "Cancellation and shutdown sequence"
    ],
    "primary_entity": "async handler or coroutine",
    "grep_patterns": {
      "boundaries": "asyncio\\.run\\|loop\\.run_until_complete\\|run_coroutine_threadsafe\\|to_thread",
      "cancellation": "cancel\\(\\)\\|CancelledError\\|shield\\|wait_for",
      "gather": "asyncio\\.gather\\|return_exceptions\\|TaskGroup"
    }
  },
  "infrastructure_automation": {
    "indicators": {
      "frameworks": ["subprocess", "paramiko", "fabric", "boto3", "ansible", "terraform"],
      "patterns": ["subprocess.run", "subprocess.Popen", "boto3.client", "ssh"],
      "directories": ["deploy/", "infra/", "automation/", "scripts/", "ops/"]
    },
    "additional_investigation": [
      "Idempotency guarantees (can operations be safely re-run?)",
      "Rollback patterns (what happens when a step fails mid-sequence?)",
      "Credential handling (how are secrets loaded, rotated, scoped?)",
      "Timeout chains (nested timeouts, deadline propagation)",
      "Dry-run support and validation modes",
      "Resource cleanup on failure (partial creates, orphaned resources)"
    ],
    "additional_output_sections": [
      "Operation idempotency matrix (which operations are safe to re-run)",
      "Credential flow (source → usage → rotation)",
      "Failure recovery procedures per operation"
    ],
    "primary_entity": "automation operation or deployment step",
    "grep_patterns": {
      "subprocess": "subprocess\\.run\\|subprocess\\.Popen\\|subprocess\\.check",
      "credentials": "AWS_ACCESS\\|SECRET_KEY\\|credentials\\|get_secret\\|vault",
      "timeout": "timeout\\|deadline\\|Timeout\\|wait_for"
    }
  },
  "plugin_system": {
    "indicators": {
      "frameworks": ["pluggy", "stevedore", "importlib", "entry_points", "pkg_resources"],
      "patterns": ["entry_points", "hookimpl", "hookspec", "importlib.import_module", "load_entry_point"],
      "directories": ["plugins/", "extensions/", "contrib/", "addons/"]
    },
    "additional_investigation": [
      "Plugin discovery mechanism (entry_points, directory scanning, registry)",
      "Plugin lifecycle hooks (init, activate, deactivate, unload)",
      "Version compatibility between host and plugins",
      "Plugin isolation (shared state, namespace conflicts)",
      "Error handling for bad plugins (graceful degradation vs fail-fast)",
      "Plugin configuration and dependency injection"
    ],
    "additional_output_sections": [
      "Plugin discovery and loading sequence",
      "Plugin API surface (hooks available to plugins)",
      "Plugin compatibility requirements"
    ],
    "primary_entity": "plugin or extension",
    "grep_patterns": {
      "discovery": "entry_points\\|iter_entry_points\\|importlib\\.import_module\\|load_plugin",
      "hooks": "hookimpl\\|hookspec\\|hook_\\|on_\\|register_hook",
      "lifecycle": "activate\\|deactivate\\|unload\\|initialize_plugin"
    }
  },
  "web_api_js": {
    "indicators": {
      "frameworks": ["express", "fastify", "koa", "hapi", "nestjs", "@nestjs/core", "hono"],
      "patterns": ["app.get(", "app.post(", "router.get(", "@Get(", "@Controller(", "Hono("],
      "directories": ["routes/", "api/", "controllers/", "middleware/"]
    },
    "additional_investigation": [
      "Express/Fastify middleware chain and execution order",
      "Request validation (zod, joi, class-validator)",
      "Authentication middleware (passport, custom JWT)",
      "CORS configuration",
      "Error handling middleware (app.use with 4 params or error filter)",
      "Database connection lifecycle (connection pool, per-request)"
    ],
    "additional_output_sections": [
      "API endpoint index (route → handler → service)",
      "Auth flow trace",
      "Middleware chain with execution order"
    ],
    "primary_entity": "API route handler",
    "grep_patterns": {
      "auth": "passport\\|jwt\\|Bearer\\|authenticate\\|@UseGuards",
      "middleware": "app\\.use\\|middleware\\|@UseInterceptors\\|@UseFilters",
      "rate_limit": "rateLimit\\|throttle\\|@Throttle"
    }
  },
  "cli_tool_js": {
    "indicators": {
      "frameworks": ["commander", "yargs", "oclif", "meow", "cac", "gunshi", "clipanion"],
      "patterns": ["program.command(", ".option(", ".argument(", "defineCommand(", "define("],
      "directories": ["commands/", "cli/", "bin/"]
    },
    "additional_investigation": [
      "Command hierarchy and subcommand dispatch",
      "Argument parsing and validation",
      "Output modes (table, JSON, plain text)",
      "Exit code conventions",
      "stdin/stdout/stderr usage patterns",
      "Configuration file loading and merge strategy"
    ],
    "additional_output_sections": [
      "Command tree with argument signatures",
      "Output format documentation",
      "Exit code table"
    ],
    "primary_entity": "CLI command",
    "grep_patterns": {
      "commands": "command\\|subcommand\\|\\.action\\|defineCommand",
      "options": "\\.option\\|--\\w+\\|process\\.argv",
      "output": "console\\.log\\|process\\.stdout\\|chalk\\|picocolors"
    }
  },
  "frontend_js": {
    "indicators": {
      "frameworks": ["react", "vue", "angular", "svelte", "solid-js", "next", "nuxt"],
      "patterns": ["useState(", "useEffect(", "createSignal(", "defineComponent("],
      "directories": ["components/", "pages/", "views/", "app/"]
    },
    "additional_investigation": [
      "State management approach (Redux, Zustand, Pinia, signals)",
      "Routing configuration",
      "Data fetching patterns (SWR, React Query, fetch)",
      "Component composition patterns",
      "Build configuration (Vite, webpack, turbopack)"
    ],
    "additional_output_sections": [
      "Component hierarchy overview",
      "State management architecture",
      "Data flow from API to UI"
    ],
    "primary_entity": "component/page",
    "grep_patterns": {
      "state": "useState\\|useReducer\\|createStore\\|defineStore\\|createSignal",
      "effects": "useEffect\\|onMounted\\|onCleanup\\|watch(",
      "routing": "useRouter\\|Link\\|Route\\|navigate"
    }
  }
}
